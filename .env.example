# Copy to .env and fill in values

# Server
PORT=3001
NODE_ENV=development

# PostgreSQL (Railway provides DATABASE_URL automatically in prod)
DATABASE_URL=postgresql://user:password@localhost:5432/windy

# Optional: NREL API key for enhanced wind data
# Get one free at https://developer.nrel.gov/signup/
NREL_API_KEY=

# Optional: EIA API key for real-time electricity rates
# Get one free at https://www.eia.gov/opendata/register.php
EIA_API_KEY=
